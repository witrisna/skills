// ── DeviceProfileCallback (:foundation:device:device-profile) ─────────────────
// implementation(project(":foundation:device:device-profile"))

@Composable
fun DeviceProfileCallbackField(callback: DeviceProfileCallback, onNext: () -> Unit) {
    val scope = rememberCoroutineScope()
    var isLoading by remember { mutableStateOf(true) }

    LaunchedEffect(true) {
        scope.launch {
            callback.collect {
                collectors {
                    clear()
                    add(PlatformCollector())
                    add(HardwareCollector())
                    add(NetworkCollector())
                    add(TelephonyCollector)
                    add(BluetoothCollector)
                    add(BrowserCollector)
                }
            }
            isLoading = false
            onNext()
        }
    }

    if (isLoading) {
        AutoProgressIndicator(message = "Gathering Device Profile...")
    }
}

// ── ReCaptchaEnterpriseCallback (:recaptcha-enterprise) ──────────────────────
// implementation(project(":recaptcha-enterprise"))

@Composable
fun ReCaptchaEnterpriseCallbackField(callback: ReCaptchaEnterpriseCallback, onNext: () -> Unit) {
    val scope = rememberCoroutineScope()
    var isLoading by remember { mutableStateOf(true) }

    LaunchedEffect(true) {
        scope.launch {
            callback.verify { }
                .onSuccess {
                    isLoading = false
                    onNext()
                }
                .onFailure {
                    isLoading = false
                    onNext() // proceed even on failure — adjust for production
                }
        }
    }

    if (isLoading) {
        AutoProgressIndicator(message = "ReCaptcha verification in progress...")
    }
}

