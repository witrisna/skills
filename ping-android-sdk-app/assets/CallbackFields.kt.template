// ── FidoRegistrationCallback (:mfa:fido) ──────────────────────────────────────
// implementation(project(":mfa:fido"))

@Composable
fun FidoRegistrationField(callback: FidoRegistrationCallback, onNext: () -> Unit) {
    val scope = rememberCoroutineScope()
    val currentOnNext by rememberUpdatedState(onNext)
    var deviceName by remember { mutableStateOf(Build.MODEL) }
    var showProgress by remember { mutableStateOf(false) }

    Box(
        modifier = Modifier.padding(4.dp).fillMaxWidth(),
        contentAlignment = Alignment.Center,
    ) {
        Column(modifier = Modifier.fillMaxWidth()) {
            if (showProgress) {
                CircularProgressIndicator(modifier = Modifier.align(Alignment.CenterHorizontally))
                Spacer(Modifier.height(8.dp))
            }
            OutlinedTextField(
                modifier = Modifier.fillMaxWidth(),
                value = deviceName,
                onValueChange = { deviceName = it },
                label = { Text("Device Name") },
            )
            Spacer(Modifier.height(8.dp))
            Button(
                modifier = Modifier.align(Alignment.End),
                onClick = {
                    showProgress = true
                    scope.launch {
                        callback.register(deviceName)
                            .onSuccess { currentOnNext() }
                            .onFailure {
                                Log.e("FidoRegistration", "Failed to register", it)
                                currentOnNext()
                            }
                    }
                },
            ) {
                Text("Continue")
            }
        }
    }
}

