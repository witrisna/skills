@Composable
fun ConsentMappingCallbackField(callback: ConsentMappingCallback, onNodeUpdated: () -> Unit) {
    var accepted by remember(callback) { mutableStateOf(false) }

    Column(
        modifier = Modifier
            .padding(16.dp)
            .fillMaxWidth(),
    ) {
        Text(text = "Name: ${callback.name}", style = MaterialTheme.typography.titleMedium)
        Spacer(Modifier.height(4.dp))
        Text(text = "Display Name: ${callback.displayName}", style = MaterialTheme.typography.titleMedium)
        Spacer(Modifier.height(4.dp))
        Text(text = "Access Level: ${callback.accessLevel}", style = MaterialTheme.typography.bodyMedium)
        Text(text = "Required: ${callback.isRequired}", style = MaterialTheme.typography.bodyMedium)
        callback.fields.forEach { field ->
            Text(text = "Field: $field", style = MaterialTheme.typography.bodySmall)
        }
        if (callback.message.isNotEmpty()) {
            Spacer(Modifier.height(4.dp))
            Text(text = callback.message, style = MaterialTheme.typography.bodySmall)
        }
        Spacer(Modifier.height(8.dp))
        Row(verticalAlignment = Alignment.CenterVertically) {
            Switch(
                checked = accepted,
                onCheckedChange = {
                    accepted = it
                    callback.accepted = it
                    onNodeUpdated()
                },
            )
            Spacer(Modifier.height(8.dp))
            Text(text = "I consent", modifier = Modifier.padding(start = 8.dp))
        }
    }
}

// ── KbaCreateCallback ─────────────────────────────────────────────────────────

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun KbaCreateCallbackField(callback: KbaCreateCallback, onNodeUpdated: () -> Unit) {
    var expanded by remember(callback) { mutableStateOf(false) }
    var selectedItem by remember(callback) { mutableStateOf(callback.predefinedQuestions[0]) }
    var isCustomQuestion by remember(callback) { mutableStateOf(false) }
    var customQuestion by remember(callback) { mutableStateOf("") }
    var answer by remember(callback) { mutableStateOf("") }

    // Set the default question on first composition
    LaunchedEffect(true) { callback.selectedQuestion = selectedItem }

    Column(
        modifier = Modifier
            .padding(8.dp)
            .fillMaxWidth(),
    ) {
        ExposedDropdownMenuBox(
            expanded = expanded,
            onExpandedChange = { expanded = !expanded },
        ) {
            TextField(
                modifier = Modifier.menuAnchor(MenuAnchorType.PrimaryNotEditable, true),
                value = if (isCustomQuestion) "Provide your own" else selectedItem,
                onValueChange = {},
                readOnly = true,
                label = { Text(callback.prompt) },
                trailingIcon = { ExposedDropdownMenuDefaults.TrailingIcon(expanded) },
                colors = ExposedDropdownMenuDefaults.textFieldColors(),
            )
            ExposedDropdownMenu(expanded = expanded, onDismissRequest = { expanded = false }) {
                callback.predefinedQuestions.forEachIndexed { index, question ->
                    DropdownMenuItem(
                        text = { Text(question) },
                        onClick = {
                            selectedItem = question
                            isCustomQuestion = false
                            expanded = false
                            callback.selectedQuestion = callback.predefinedQuestions[index]
                            onNodeUpdated()
                        },
                    )
                }
                if (callback.allowUserDefinedQuestions) {
                    DropdownMenuItem(
                        text = { Text("Provide your own") },
                        onClick = {
                            isCustomQuestion = true
                            expanded = false
                            callback.selectedQuestion = ""
                            onNodeUpdated()
                        },
                    )
                }
            }
        }

        if (isCustomQuestion) {
            OutlinedTextField(
                modifier = Modifier.fillMaxWidth().padding(top = 8.dp),
                value = customQuestion,
                onValueChange = {
                    customQuestion = it
                    callback.selectedQuestion = it
                    onNodeUpdated()
                },
                label = { Text("Your Question") },
            )
        }

        OutlinedTextField(
            modifier = Modifier.fillMaxWidth().padding(top = 8.dp),
            value = answer,
            onValueChange = {
                answer = it
                callback.selectedAnswer = it
                onNodeUpdated()
            },
            label = { Text("Answer") },
        )
    }
}

