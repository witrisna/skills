// ── PingOneProtectInitializeCallback (:protect) ───────────────────────────────
// implementation(project(":protect"))

@Composable
fun PingOneProtectInitializeField(field: PingOneProtectInitializeCallback, onNext: () -> Unit) {
    val scope = rememberCoroutineScope()
    var isLoading by remember(field) { mutableStateOf(true) }

    LaunchedEffect(field) {
        scope.launch {
            try {
                val start = System.currentTimeMillis()
                field.start()
                val remaining = 2_000L - (System.currentTimeMillis() - start)
                if (remaining > 0) delay(remaining)
                isLoading = false
                onNext()
            } catch (e: Exception) {
                isLoading = false
            }
        }
    }

    if (isLoading) {
        AutoProgressIndicator(message = "Initializing security checks...")
    }
}

