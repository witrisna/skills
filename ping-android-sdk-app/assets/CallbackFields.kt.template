@Composable
fun NameCallbackField(field: NameCallback, onNodeUpdated: () -> Unit) {
    var text by remember(field) { mutableStateOf(field.name) }
    Row(
        modifier = Modifier.padding(4.dp).fillMaxWidth()
    ) {
        Spacer(Modifier.weight(1f))
        OutlinedTextField(
            modifier = Modifier.wrapContentWidth(Alignment.CenterHorizontally),
            value = text,
            onValueChange = {
                text = it
                field.name = it
                onNodeUpdated()
            },
            label = { Text(field.prompt) },
        )
        Spacer(Modifier.weight(1f))
    }
}

// ── PasswordCallback ──────────────────────────────────────────────────────────

@Composable
fun PasswordCallbackField(field: PasswordCallback, onNodeUpdated: () -> Unit) {
    var password by remember(field) { mutableStateOf("") }
    var visible by remember { mutableStateOf(false) }

    Row(modifier = Modifier.padding(4.dp).fillMaxWidth()) {
        Spacer(Modifier.weight(1f))
        OutlinedTextField(
            modifier = Modifier.wrapContentWidth(Alignment.CenterHorizontally),
            value = password,
            onValueChange = {
                password = it
                field.password = it
                onNodeUpdated()
            },
            label = { Text(field.prompt) },
            visualTransformation = if (visible) VisualTransformation.None else PasswordVisualTransformation(),
            keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Password),
            trailingIcon = {
                IconButton(onClick = { visible = !visible }) {
                    Icon(
                        if (visible) Icons.Filled.Visibility else Icons.Filled.VisibilityOff,
                        contentDescription = if (visible) "Hide password" else "Show password",
                    )
                }
            },
        )
        Spacer(Modifier.weight(1f))
    }
}

