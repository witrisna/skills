// ── PollingWaitCallback ───────────────────────────────────────────────────────

/**
 * Displays [field.message] and automatically advances after [field.waitTime] milliseconds.
 * This composable handles its own "showNext = false" logic by never calling [onNext] via button.
 */
@Composable
fun PollingWaitCallbackField(field: PollingWaitCallback, onNext: () -> Unit) {
    LaunchedEffect(field) {
        delay(field.waitTime.toLong())
        onNext()
    }
    Text(
        text = field.message,
        modifier = Modifier
            .fillMaxWidth()
            .padding(4.dp),
    )
    Spacer(Modifier.height(8.dp))
}

